# --- Core ---
# Railway: attach a PostgreSQL service and reference it:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/archie_db
ENVIRONMENT=development
# Production backend base URL (set to your deployed Railway service)
BACKEND_BASE_URL=https://web-production-3b743.up.railway.app

# --- Auth (generate strong values; NEVER commit real keys) ---
API_KEY=change-me-client-api-key
ADMIN_API_KEY=change-me-admin-api-key
ADMIN_USERNAME=admin

# --- Authentication (Google OAuth2 + JWT) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS: comma-separated origins, or * for permissive dev mode ---
CORS_ORIGINS=*

# --- AI engine proxy target for POST /chat ---
AI_ENGINE_URL=http://127.0.0.1:8001/chat

# --- Session engine tuning (seconds) ---
SESSION_HEARTBEAT_TIMEOUT_SECONDS=180
SESSION_IDLE_TIMEOUT_SECONDS=900
SESSION_RECOVERY_WINDOW_SECONDS=86400

# --- Rate limiting (requests/minute per API key or IP; 0 disables) ---
RATE_LIMIT_PER_MINUTE=120

# --- Connection pool ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Production Database (Railway will inject this automatically) ---
# DATABASE_URL=${{Postgres.DATABASE_URL}}

# --- Production API Keys (NEVER commit real values) ---
# API_KEY=your-production-api-key
# ADMIN_API_KEY=your-production-admin-api-key
TESTING=False